<?xml version="1.0" encoding="utf-8"?>
<!-- Banner 320×180dp para Android TV launcher -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo degradado oscuro -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D0D0D"
                android:endColor="#1A0000"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
    <!-- Línea de acento izquierda -->
    <item android:right="304dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8001C"/>
        </shape>
    </item>
    <!-- Logo TNET play centrado -->
    <item
        android:left="32dp"
        android:right="32dp"
        android:top="54dp"
        android:bottom="54dp">
        <bitmap
            android:src="@drawable/tnet_logo"
            android:gravity="center"
            android:tileMode="disabled"/>
    </item>
</layer-list>
